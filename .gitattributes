# Consistent line endings
*.md text eol=lf
*.yaml text eol=lf
*.ts text eol=lf
*.json text eol=lf

# Relay: counter files use 'ours' merge to avoid conflicts
# After merging, run `relay doctor --fix` to reconcile counters
.relay/tasks/.counter merge=ours
.relay/plans/.counter merge=ours
.relay/docs/.counter merge=ours
