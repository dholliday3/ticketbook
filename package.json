{
  "name": "relay",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "bin": {
    "relay": "bin/relay.ts"
  },
  "scripts": {
    "dev": "trap 'kill 0' EXIT; bun bin/relay.ts --port 4242 --no-ui & cd packages/ui && bunx vite",
    "build:binary": "bash scripts/build-binary.sh",
    "typecheck": "bash scripts/typecheck.sh",
    "lint": "bunx eslint packages/core/src packages/server/src",
    "test": "bun test",
    "test:install": "bun test ./scripts/install.test.ts",
    "pretest:e2e": "bun --filter \"@relay/ui\" build && bunx playwright install chromium",
    "test:e2e": "bunx playwright test --config e2e/playwright.config.ts",
    "test:e2e:headed": "bunx playwright test --config e2e/playwright.config.ts --headed",
    "test:e2e:ui": "bunx playwright test --config e2e/playwright.config.ts --ui",
    "test:all": "bun run test && bun run test:install && bun run test:e2e",
    "term:debug": "bun scripts/term-debug.ts",
    "db:reset": "bun -e \"import { resetDb } from './packages/server/src/db.ts'; resetDb('.'); console.log('Database reset.');\"",
    "demo:record": "webreel record"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.11",
    "eslint": "^9.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.0.0",
    "webreel": "^0.1.4"
  }
}
